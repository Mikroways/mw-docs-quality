#!/bin/sh
# Ordena alfabéticamente (por sección) los archivos dictionaries/*.txt staged.
set -e

staged=$(git diff --cached --name-only --diff-filter=ACM | grep "^dictionaries/.*\.txt$" || true)
[ -z "$staged" ] && exit 0

for dict in $staged; do
  [ -f "$dict" ] || continue

  tmp=$(mktemp)
  section_tmp=$(mktemp)

  flush_section() {
    [ -s "$section_tmp" ] && sort -f < "$section_tmp" >> "$tmp"
    : > "$section_tmp"
  }

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      \#*) flush_section; printf '%s\n' "$line" >> "$tmp" ;;
      "")  flush_section; printf '\n' >> "$tmp" ;;
      *)   printf '%s\n' "$line" >> "$section_tmp" ;;
    esac
  done < "$dict"
  flush_section

  rm -f "$section_tmp"
  mv "$tmp" "$dict"
  git add "$dict"
  echo "sort-dict: $dict"
done
